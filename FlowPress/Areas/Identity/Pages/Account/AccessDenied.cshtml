@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Acceso denegado";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FlowPress — Acceso denegado</title>
    <link rel="stylesheet" href="~/css/flowpress.css" />
    <style>
        .error-page {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 3rem;
            position: relative;
            overflow: hidden;
        }

        .error-page__bg {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(232, 160, 32, 0.05) 0%, transparent 70%);
            pointer-events: none;
        }

        .error-page__logo {
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 900;
            position: absolute;
            top: 3rem;
            left: 4rem;
        }

            .error-page__logo span {
                color: var(--accent);
            }

        .error-page__code {
            font-family: var(--font-display);
            font-size: clamp(6rem, 20vw, 14rem);
            font-weight: 900;
            line-height: 1;
            color: rgba(232, 160, 32, 0.1);
            margin-bottom: 1rem;
        }

        .error-page__title {
            font-family: var(--font-display);
            font-size: clamp(1.5rem, 4vw, 2.5rem);
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .error-page__desc {
            font-size: 1rem;
            color: var(--fg-muted);
            max-width: 420px;
            line-height: 1.7;
            margin-bottom: 2.5rem;
        }

        .error-actions {
            display: flex;
            gap: 1.5rem;
            align-items: center;
        }
    </style>
</head>
<body>
    <div class="error-page">
        <div class="error-page__bg"></div>
        <a href="/" class="error-page__logo">Flow<span>Press</span></a>
        <div class="error-page__code">403</div>
        <h1 class="error-page__title">Acceso denegado</h1>
        <p class="error-page__desc">
            No tienes permisos para acceder a esta sección.
            Si crees que esto es un error, contacta al administrador.
        </p>
        <div class="error-actions">
            <a href="/" class="btn-primary">Volver al inicio</a>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn-ghost">Cambiar cuenta</a>
        </div>
    </div>
</body>
</html>