@page
@model RegisterModel
@{
    ViewData["Title"] = "Crear cuenta";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FlowPress — Crear cuenta</title>
    <link rel="stylesheet" href="~/css/flowpress.css" />
    <style>
        .login-page {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .login-left {
            background: var(--bg);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 3rem 4rem;
            position: relative;
            overflow: hidden;
            border-right: 1px solid var(--border);
        }

        .login-left__bg {
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse 70% 50% at 30% 60%, rgba(232, 160, 32, 0.07) 0%, transparent 60%),
                radial-gradient(ellipse 40% 40% at 80% 20%, rgba(232, 160, 32, 0.03) 0%, transparent 50%);
            pointer-events: none;
        }

        .login-left__grid {
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 60px 60px;
            mask-image: radial-gradient(ellipse 80% 80% at 30% 60%, black, transparent);
            pointer-events: none;
        }

        .login-left__logo {
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 900;
            letter-spacing: -0.02em;
            position: relative;
            z-index: 1;
        }

        .login-left__logo span { color: var(--accent); }

        .login-left__content {
            position: relative;
            z-index: 1;
        }

        .login-left__eyebrow {
            font-size: 0.7rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--accent);
            margin-bottom: 1.5rem;
        }

        .login-left__title {
            font-family: var(--font-display);
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 900;
            line-height: 0.95;
            letter-spacing: -0.03em;
            margin-bottom: 1.5rem;
        }

        .login-left__title em {
            font-style: italic;
            color: var(--accent);
        }

        .login-left__desc {
            font-size: 0.95rem;
            color: var(--fg-muted);
            line-height: 1.7;
            max-width: 360px;
        }

        .login-left__footer {
            font-size: 0.75rem;
            color: var(--fg-muted);
            letter-spacing: 0.05em;
            position: relative;
            z-index: 1;
        }

        .login-right {
            background: var(--bg-2);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem;
        }

        .login-form-wrap {
            width: 100%;
            max-width: 400px;
            animation: fadeUp 0.8s 0.2s both;
        }

        .login-form-wrap h2 {
            font-family: var(--font-display);
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .login-form-wrap > p {
            font-size: 0.9rem;
            color: var(--fg-muted);
            margin-bottom: 2.5rem;
        }

        .login-form-wrap > p a {
            color: var(--accent);
            transition: opacity 0.2s;
        }

        .login-form-wrap > p a:hover { opacity: 0.8; }

        .field { margin-bottom: 1.5rem; }

        .field label {
            display: block;
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--fg-muted);
            margin-bottom: 0.6rem;
        }

        .field input {
            width: 100%;
            background: var(--bg);
            border: 1px solid var(--border);
            color: var(--fg);
            font-family: var(--font-body);
            font-size: 0.95rem;
            padding: 0.9rem 1.2rem;
            outline: none;
            transition: border-color 0.2s;
            -webkit-appearance: none;
        }

        .field input:focus { border-color: var(--accent); }

        .field input::placeholder {
            color: var(--fg-muted);
            opacity: 0.5;
        }

        .field-error {
            font-size: 0.75rem;
            color: #e85020;
            margin-top: 0.4rem;
            letter-spacing: 0.03em;
        }

        .login-error {
            background: rgba(232, 80, 32, 0.08);
            border: 1px solid rgba(232, 80, 32, 0.3);
            color: #e85020;
            font-size: 0.85rem;
            padding: 0.9rem 1.2rem;
            margin-bottom: 1.5rem;
        }

        .btn-login {
            width: 100%;
            padding: 1rem;
            background: var(--accent);
            color: var(--bg);
            border: none;
            font-family: var(--font-body);
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.2s, transform 0.2s;
        }

        .btn-login:hover {
            background: var(--accent-2);
            transform: translateY(-1px);
        }

        .form-divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 2rem 0;
        }

        .form-divider::before,
        .form-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .form-divider span {
            font-size: 0.7rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--fg-muted);
        }

        .btn-register {
            display: block;
            width: 100%;
            padding: 0.9rem;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--fg-muted);
            font-family: var(--font-body);
            font-size: 0.85rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            text-align: center;
            cursor: pointer;
            transition: border-color 0.2s, color 0.2s;
            text-decoration: none;
        }

        .btn-register:hover {
            border-color: var(--fg-muted);
            color: var(--fg);
        }

        @@media (max-width: 768px) {
            .login-page { grid-template-columns: 1fr; }
            .login-left { display: none; }
            .login-right { padding: 2rem; }
        }
    </style>
</head>
<body>
    <div class="login-page">

        <div class="login-left">
            <div class="login-left__bg"></div>
            <div class="login-left__grid"></div>
            <a href="/" class="login-left__logo">Flow<span>Press</span></a>
            <div class="login-left__content">
                <p class="login-left__eyebrow">Únete ahora</p>
                <h2 class="login-left__title">
                    Empieza a<br>
                    leer lo que<br>
                    <em>importa.</em>
                </h2>
                <p class="login-left__desc">
                    Crea tu cuenta y accede a contenido agregado
                    desde múltiples fuentes en tiempo real.
                </p>
            </div>
            <p class="login-left__footer">SC-701 · Programación Avanzada Web · @DateTime.Now.Year</p>
        </div>

        <div class="login-right">
            <div class="login-form-wrap">
                <h2>Crear cuenta</h2>
                <p>¿Ya tienes cuenta? <a asp-area="Identity" asp-page="/Account/Login">Ingresa aquí</a></p>

                @if (!ModelState.IsValid)
                {
                    <div class="login-error">
                        <div asp-validation-summary="All" class="login-error"></div> 
                    </div>
                }


                <form method="post">

                    <div class="field">
                        <label asp-for="Input.UserName">Nombre de usuario</label>
                        <input asp-for="Input.UserName"
                               type="text"
                               placeholder="ej. Naruto777"
                               autocomplete="username" />
                        <span asp-validation-for="Input.UserName" class="field-error"></span>
                    </div>

                    <div class="field">
                        <label asp-for="Input.Email">Correo electrónico</label>
                        <input asp-for="Input.Email"
                               type="email"
                               placeholder="tu@correo.com"
                               autocomplete="username" />
                        <span asp-validation-for="Input.Email" class="field-error"></span>
                    </div>

                    <div class="field">
                        <label asp-for="Input.Password">Contraseña</label>
                        <input asp-for="Input.Password"
                               type="password"
                               placeholder="••••••••"
                               autocomplete="new-password" />
                        <span asp-validation-for="Input.Password" class="field-error"></span>
                    </div>

                    <div class="field">
                        <label asp-for="Input.ConfirmPassword">Confirmar contraseña</label>
                        <input asp-for="Input.ConfirmPassword"
                               type="password"
                               placeholder="••••••••"
                               autocomplete="new-password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
                    </div>


                    <button type="submit" class="btn-login">Crear cuenta</button>

                    <div class="form-divider"><span>o</span></div>

                    <a asp-area="Identity" asp-page="/Account/Login" class="btn-register">
                        Ya tengo cuenta
                    </a>
                </form>
            </div>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>