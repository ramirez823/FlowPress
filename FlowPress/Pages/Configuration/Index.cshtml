@page
@model FlowPress.Pages.Configuration.IndexModel
@{
    ViewData["Title"] = "Configuración · FlowPress";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <link rel="stylesheet" href="~/css/flowpress.css" />
    <style>
        /* ── ESTILOS ESPECÍFICOS PARA CONFIGURACIÓN ── */
        .config-section {
            padding: 8rem 4rem 4rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .config-tabs {
            display: flex;
            gap: 2rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: 3rem;
            padding-bottom: 1rem;
        }

        .config-tab {
            background: none;
            border: none;
            color: var(--fg-muted);
            font-family: var(--font-body);
            font-size: 0.9rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 0.5rem 0;
            cursor: pointer;
            transition: color 0.2s;
            position: relative;
        }

            .config-tab:hover {
                color: var(--fg);
            }

            .config-tab.active {
                color: var(--accent);
            }

                .config-tab.active::after {
                    content: '';
                    position: absolute;
                    bottom: -1rem;
                    left: 0;
                    right: 0;
                    height: 2px;
                    background: var(--accent);
                }

        .tab-pane {
            display: none;
            animation: fadeIn 0.3s ease;
        }

            .tab-pane.active {
                display: block;
            }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .config-table {
            width: 100%;
            border-collapse: collapse;
            margin: 2rem 0 3rem;
            background: var(--bg-2);
            border: 1px solid var(--border);
        }

            .config-table th {
                text-align: left;
                padding: 1rem;
                font-size: 0.7rem;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--accent);
                font-weight: 400;
                border-bottom: 1px solid var(--border);
                background: var(--bg-3);
            }

            .config-table td {
                padding: 1rem;
                border-bottom: 1px solid var(--border);
                color: var(--fg);
            }

            .config-table tr:last-child td {
                border-bottom: none;
            }

            .config-table tr:hover td {
                background: var(--bg-3);
            }

        .config-checkbox {
            width: 20px;
            height: 20px;
            accent-color: var(--accent);
            cursor: pointer;
        }

        .config-form {
            background: var(--bg-2);
            border: 1px solid var(--border);
            padding: 2rem;
            margin-top: 2rem;
        }

            .config-form h4 {
                font-family: var(--font-display);
                font-size: 1.3rem;
                margin-bottom: 2rem;
                color: var(--fg);
            }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            font-size: 0.8rem;
            letter-spacing: 0.05em;
            color: var(--fg-muted);
            text-transform: uppercase;
        }

        .form-control, .form-select {
            width: 100%;
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 0.8rem 1rem;
            color: var(--fg);
            font-family: var(--font-body);
            font-size: 0.95rem;
            transition: border-color 0.2s;
        }

            .form-control:focus, .form-select:focus {
                outline: none;
                border-color: var(--accent);
            }

            .form-control[type="password"] {
                letter-spacing: 0.2em;
            }

        .text-danger {
            display: block;
            margin-top: 0.3rem;
            font-size: 0.8rem;
            color: #ff4d4d;
        }

        .btn-config-primary {
            background: var(--accent);
            border: none;
            color: var(--bg);
            padding: 0.8rem 2rem;
            font-family: var(--font-body);
            font-size: 0.8rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.2s;
        }

            .btn-config-primary:hover {
                background: var(--accent-2);
            }

        .btn-config-secondary {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--fg-muted);
            padding: 0.8rem 2rem;
            font-family: var(--font-body);
            font-size: 0.8rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: border-color 0.2s, color 0.2s;
            margin-left: 0.5rem;
        }

            .btn-config-secondary:hover {
                border-color: var(--fg-muted);
                color: var(--fg);
            }

        .btn-config-danger {
            background: transparent;
            border: 1px solid #a00;
            color: #f66;
            padding: 0.4rem 1rem;
            font-size: 0.7rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
        }

            .btn-config-danger:hover {
                background: #a00;
                color: white;
            }

        .action-cell {
            display: flex;
            gap: 0.5rem;
        }

        .mb-3 {
            margin-bottom: 1rem;
        }

        /* Responsive */
        @@media (max-width: 900px) {
            .config-section {
                padding: 6rem 2rem 2rem;
            }

            .config-tabs {
                flex-direction: column;
                gap: 1rem;
            }

            .config-table {
                font-size: 0.85rem;
            }

                .config-table th, .config-table td {
                    padding: 0.75rem;
                }

            .action-cell {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

    <!-- NAVBAR (copiado de la landing) -->
    <nav class="nav">
        <a href="/" class="nav__logo">Flow<span>Press</span></a>
        <ul class="nav__links">
            <li><a href="/#articles">Artículos</a></li>
            <li><a href="/#how">Cómo funciona</a></li>
            <li><a href="/#sources">Fuentes</a></li>
            @if (User.IsInRole("Admin"))
            {
                <li><a asp-page="/Configuration/Index" class="active">Configuración</a></li>
            }
            @if (User.Identity.IsAuthenticated)
            {
                <li class="nav__user">
                    <span class="nav__username">@User.Identity.Name</span>
                </li>
                <li>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
                        <button type="submit" class="nav__logout">Salir</button>
                    </form>
                </li>
            }
            else
            {
                <li><a asp-area="Identity" asp-page="/Account/Login" class="nav__cta">Ingresar</a></li>
            }
        </ul>
    </nav>

    <!-- CONTENIDO PRINCIPAL -->
    <main class="config-section">
        <h1 class="section__title" style="margin-bottom: 1rem;">Configuración</h1>
        <p class="section__label" style="margin-bottom: 3rem;">Administra roles y credenciales</p>

        <!-- Tabs con JS vanilla -->
        <div class="config-tabs">
            <button class="config-tab active" data-tab="roles">Roles de usuario</button>
            <button class="config-tab" data-tab="secrets">Secrets (API Keys)</button>
            <button class="config-tab" data-tab="destacados">Destacados</button>
            <button class="config-tab" data-tab="importar">Importar</button>
        </div>

        <div class="tab-pane active" id="tab-roles">
            <table class="config-table">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Email</th>
                        <th>Es Admin?</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.UserName</td>
                            <td>@user.Email</td>
                            <td>
                                <form method="post" asp-page-handler="ToggleRole">
                                    <input type="hidden" name="SelectedUserId" value="@user.Id" />
                                    <input type="checkbox" name="IsAdmin" value="true" class="config-checkbox" @(user.IsAdmin ? "checked" : "") onchange="this.form.submit()" />
                                </form>
                            </td>
                            <td></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="tab-pane" id="tab-secrets">
            <table class="config-table">
                <thead>
                    <tr>
                        <th>Key</th>
                        <th>Fuente asociada</th>
                        <th>Última actualización</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var secret in Model.Secrets)
                    {
                        <tr>
                            <td>@secret.Key</td>
                            <td>@(secret.Source?.Name ?? "Global")</td>
                            <td>@(secret.UpdatedAt?.ToString("g") ?? secret.CreatedAt.ToString("g"))</td>
                            <td class="action-cell">
                                <form method="post" asp-page-handler="DeleteSecret" asp-route-id="@secret.Id" style="display:inline;">
                                    <button type="submit" class="btn-config-danger" onclick="return confirm('¿Eliminar este secret?')">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="config-form">
                <h4>@(Model.SecretInput.Id.HasValue ? "Editar" : "Nuevo") Secret</h4>
                <form method="post" asp-page-handler="SaveSecret">
                    <input type="hidden" asp-for="SecretInput.Id" />
                    <div class="form-group">
                        <label asp-for="SecretInput.Key" class="form-label"></label>
                        <input asp-for="SecretInput.Key" class="form-control" />
                        <span asp-validation-for="SecretInput.Key" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="SecretInput.Value" class="form-label">Valor</label>
                        <input asp-for="SecretInput.Value" class="form-control" type="password" />
                        <span asp-validation-for="SecretInput.Value" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="SecretInput.SourceId" class="form-label">Fuente (opcional)</label>
                        <select asp-for="SecretInput.SourceId" class="form-select">
                            <option value="">-- Global --</option>
                            @foreach (var source in Model.Sources)
                            {
                                <option value="@source.Id">@source.Name</option>
                            }
                        </select>
                    </div>
                    <div>
                        <button type="submit" class="btn-config-primary">Guardar</button>
                        @if (Model.SecretInput.Id.HasValue)
                        {
                            <a asp-page="Index" asp-fragment="secrets" class="btn-config-secondary">Cancelar</a>
                        }
                    </div>
                </form>
            </div>
        </div>


        <!-- destacados -->
        <div class="tab-pane" id="tab-destacados">
            @if (!Model.AllItems.Any())
            {
                <p style="color:var(--fg-muted);font-size:0.9rem;margin-top:2rem;">
                    No hay artículos importados aún. Usá la importación de JSON para agregar contenido.
                </p>
            }
            else
            {
                <table class="config-table">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Fuente</th>
                            <th>Importado</th>
                            <th>Destacado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.AllItems)
                        {
                            var vm = new FlowPress.Models.SourceItemViewModel(item);
                            <tr>
                                <td>@(vm.Normalized?.Title ?? "Sin título")</td>
                                <td>@(item.Source?.Name ?? "—")</td>
                                <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <form method="post" asp-page-handler="ToggleFeatured" asp-route-id="@item.Id">
                                        <button type="submit" class="btn-config-secondary" style="display:inline-block;text-decoration:none;">
                                            <!--style="padding:0.3rem 0.8rem;font-size:0.7rem;">-->
                                            @(item.IsFeatured ? "✓ Quitar" : "Destacar")
                                        </button>
                                    </form>
                                </td>
                                <td>
                                    <a href="/Configuration/Index?handler=Export&id=@item.Id"
                                       class="btn-config-secondary"
                                       style="display:inline-block;text-decoration:none;">
                                        ↓ JSON
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div class="tab-pane" id="tab-importar">
            @if (TempData["ImportMessage"] is string msg)
            {
                <div style="padding: 1rem 1.5rem; margin-bottom: 2rem; border: 1px solid @(TempData["ImportSuccess"] is true ? "var(--accent)" : "#a00"); background: @(TempData["ImportSuccess"] is true ? "rgba(232,160,32,0.05)" : "rgba(170,0,0,0.05)"); color: @(TempData["ImportSuccess"] is true ? "var(--accent)" : "#f66"); font-size: 0.9rem;">
                    @msg
                </div>
            }

            <div class="config-form">
                <h4>Importar artículo JSON</h4>
                <p style="color:var(--fg-muted);font-size:0.85rem;margin-bottom:2rem;">
                    El archivo debe seguir el esquema <code style="color:var(--accent)">edu.univ.ingest.v1</code>.
                    Si la fuente no existe, se creará automáticamente.
                </p>
                <form method="post" asp-page-handler="ImportJson" enctype="multipart/form-data">
                    <div class="form-group">
                        <label class="form-label">Archivo .json</label>
                        <input type="file" name="jsonFile" accept=".json" class="form-control" />
                    </div>
                    <div>
                        <button type="submit" class="btn-config-primary">Importar</button>
                    </div>
                </form>
            </div>
        </div>

    </main>

    <footer>
        <div class="footer__logo">Flow<span>Press</span></div>
        <p class="footer__copy">SC-701 · Programación Avanzada Web · @DateTime.Now.Year</p>
    </footer>

    <script>
        // Tabs
        const tabs = document.querySelectorAll('.config-tab');
        const panes = document.querySelectorAll('.tab-pane');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                const target = tab.dataset.tab; // 'roles' o 'secrets'

                // Desactivar todos
                tabs.forEach(t => t.classList.remove('active'));
                panes.forEach(p => p.classList.remove('active'));

                // Activar el seleccionado
                tab.classList.add('active');
                document.getElementById(`tab-${target}`).classList.add('active');

                // Actualizar URL hash (opcional, para compartir)
                window.location.hash = target;
            });
        });

        const hash = window.location.hash.substring(1);

        // Activar pestaña basada en hash al cargar
        if (hash === 'secrets') {
            document.querySelector('[data-tab="secrets"]')?.click();
        } else if (hash === 'destacados') {
            document.querySelector('[data-tab="destacados"]')?.click();
        } else if (hash === 'importar') {
            document.querySelector('[data-tab="importar"]')?.click();
        } else {
            document.querySelector('[data-tab="roles"]')?.click();
        }
    </script>



</body>
</html>