@page
@model FlowPress.Pages.Import.ImportModel

@{
    ViewData["Title"] = "Importar JSON";
}

<div class="container mt-5">
    <div class="card shadow-lg p-4">
        <h2 class="mb-3 text-center">Importar JSON</h2>
        <p class="text-center text-muted">
            Sube un archivo con el esquema <strong>edu.univ.ingest.v1</strong>
        </p>

        <form method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label">Seleccionar archivo JSON</label>
                <input asp-for="JsonFile" type="file" accept=".json" class="form-control" required />
                <span asp-validation-for="JsonFile" class="text-danger"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-warning">
                    Importar
                </button>
            </div>
        </form>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-success mt-3 text-center">
                @Model.Message
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert alert-danger mt-3 text-center">
                @Model.Error
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}