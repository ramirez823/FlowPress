@page
@model IndexModel
@{
    ViewData["Title"] = "FlowPress"; 
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FlowPress — Contenido que importa</title>
    <link rel="stylesheet" href="~/css/flowpress.css" />
</head>
<body>

    <!-- NAVBAR -->
    <nav class="nav">
        <a href="/" class="nav__logo">Flow<span>Press</span></a>
        <ul class="nav__links">
            <li><a href="#articles">Artículos</a></li>
            <li><a href="#how">Cómo funciona</a></li>
            <li><a href="#sources">Fuentes</a></li>

            @if (User.IsInRole("Admin"))
            {
                <li><a asp-page="/Configuration/Index">Configuración</a></li>
            }

            @if (User.Identity.IsAuthenticated)
            {
                <li class="nav__user">
                    <span class="nav__username">@User.Identity.Name</span>
                </li>
                <li>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
                        <button type="submit" class="nav__logout">Salir</button>
                    </form>
                </li>
            }
            else
            {
                <li><a asp-area="Identity" asp-page="/Account/Login" class="nav__cta">Ingresar</a></li>
            }
        </ul>
    </nav>

    <!-- HERO -->
    <section class="hero">
        <div class="hero__bg"></div>
        <div class="hero__grid-lines"></div>
        <div class="hero__content">
            <p class="hero__eyebrow">Agregador de contenido · SC-701</p>
            <h1 class="hero__title">
                Todo el<br>
                contenido<br>
                <em>que importa.</em>
            </h1>
            <p class="hero__subtitle">
                FlowPress centraliza múltiples fuentes de noticias en un solo lugar.
                Lee, filtra y guarda lo que realmente necesitas.
            </p>
            <div class="hero__actions">
                <a asp-area="Identity" asp-page="/Account/Login" class="btn-primary">Comenzar ahora</a>
                <a href="#how" class="btn-ghost">Ver cómo funciona</a>
            </div>
        </div>
        <div class="hero__scroll">
            <div class="hero__scroll-line"></div>
            <span>Scroll</span>
        </div>
    </section>

    <!-- MODAL PREVIEW DE NOTICIA -->
    <div id="newsModal" style="
        display:none;
        position:fixed;
        inset:0;
        z-index:9999;
        background:rgba(0,0,0,0.75);
        backdrop-filter:blur(4px);
        align-items:center;
        justify-content:center;
    ">
        <div style="
            background:#111;
            border:1px solid #2a2a2a;
            border-radius:8px;
            max-width:680px;
            width:90%;
            max-height:85vh;
            overflow-y:auto;
            position:relative;
            box-shadow:0 0 60px rgba(0,0,0,0.8);
        ">
            <!-- Barra dorada superior -->
            <div style="height:3px;background:#b8860b;border-radius:8px 8px 0 0;"></div>

            <!-- Imagen -->
            <img id="modal-image" src="" alt=""
                 style="width:100%;max-height:240px;object-fit:cover;display:none;" />

            <!-- Header -->
            <div style="padding:1.5rem 1.5rem 0.5rem;display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;">
                <div>
                    <p id="modal-category" style="font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;color:#b8860b;margin:0 0 0.4rem;"></p>
                    <h2 id="modal-title" style="font-size:1.3rem;font-weight:700;color:#fff;margin:0;line-height:1.4;"></h2>
                </div>
                <button onclick="closeNewsModal()" style="background:none;border:none;color:#666;font-size:1.4rem;cursor:pointer;padding:0;line-height:1;flex-shrink:0;margin-top:2px;">✕</button>
            </div>

            <!-- Body -->
            <div style="padding:1rem 1.5rem 1.5rem;">
                <p id="modal-summary" style="color:#aaa;line-height:1.75;font-size:0.95rem;margin:0 0 1.25rem;"></p>
                <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1.5rem;">
                    <span id="modal-source" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;color:#555;"></span>
                    <span style="color:#333;">·</span>
                    <span id="modal-date" style="font-size:0.75rem;color:#555;"></span>
                </div>

                <!-- Botones -->
                <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
                    <a id="modal-link" href="#" target="_blank" rel="noopener" style="
                        display:inline-block;padding:0.65rem 1.4rem;
                        background:#b8860b;color:#000;font-weight:700;
                        font-size:0.85rem;letter-spacing:0.05em;
                        text-decoration:none;border-radius:4px;">
                        Ver noticia completa →
                    </a>
                    <button id="modal-btn-download" onclick="downloadArticleJson()" style="
                        padding:0.65rem 1.2rem;
                        background:none;
                        border:1px solid #444;
                        color:#aaa;
                        font-size:0.85rem;
                        border-radius:4px;
                        cursor:pointer;">
                        ↓ Descargar JSON
                    </button>
                    <button onclick="closeNewsModal()" style="
                        padding:0.65rem 1.2rem;background:none;
                        border:1px solid #333;color:#666;
                        font-size:0.85rem;border-radius:4px;cursor:pointer;">
                        Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- CARRUSEL -->
    @if (Model.NewsItems.Any())
    {
        <section class="carousel-section" id="news">
            <div class="section__header">
                <div>
                    <p class="section__label">En tiempo real</p>
                    <h2 class="section__title reveal">Últimas<br>noticias</h2>
                </div>
                <span id="carousel-counter" style="font-size:0.8rem;color:var(--fg-muted);letter-spacing:0.1em;text-transform:uppercase;"></span>
            </div>
            <div class="carousel-wrapper">
                <div class="carousel-track" id="carouselTrack"></div>
                <div class="carousel-progress" id="carouselProgress"></div>
            </div>
            <div class="carousel-controls">
                <div class="carousel-indicators" id="carouselDots"></div>
                <div class="carousel-nav">
                    <button class="carousel-btn" id="carouselPrev">←</button>
                    <button class="carousel-btn" id="carouselNext">→</button>
                </div>
            </div>
        </section>

        <script>
            const newsItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.NewsItems.Select(i => new {
                    title    = i.Normalized?.Title ?? "Sin título",
                    summary  = i.Normalized?.Summary ?? i.Normalized?.Content ?? "",
                    category = i.Normalized?.Category?.Primary ?? "General",
                    source   = i.Source?.Name ?? i.Schema?.Name ?? "Fuente",
                    date     = i.Normalized?.PublishedAt.ToString("dd MMM yyyy"),
                    url      = i.Normalized?.Url ?? "#",
                    image    = i.Normalized?.ImageUrl ?? "",
                    // Campos extra para el JSON de exportación
                    sourceId       = i.Source?.Id.ToString() ?? "",
                    sourceUrl      = i.Source?.Url ?? "",
                    requiresSecret = i.Source?.RequiresSecret ?? false,
                    externalId     = i.Normalized?.ExternalId ?? "",
                    content        = i.Normalized?.Content ?? "",
                    author         = i.Normalized?.Author ?? "",
                    language       = i.Normalized?.Language ?? "",
                    publishedAt    = i.Normalized?.PublishedAt.ToString("yyyy-MM-ddTHH:mm:ssZ"),
                    secondaryCategories = i.Normalized?.Category?.Secondary ?? new List<string>(),
                    sourceItemId   = i.SourceItemId  // 0 si viene de API, >0 si está en BD
                })
            ));

            const CARDS_PER_PAGE = 3;
            const INTERVAL_MS    = 40000;
            let currentPage      = 0;
            let timer            = null;
            let progressStart    = null;

            const track      = document.getElementById('carouselTrack');
            const dots       = document.getElementById('carouselDots');
            const progress   = document.getElementById('carouselProgress');
            const counter    = document.getElementById('carousel-counter');
            const totalPages = Math.ceil(newsItems.length / CARDS_PER_PAGE);

            function renderDots() {
                dots.innerHTML = '';
                for (let i = 0; i < totalPages; i++) {
                    const dot = document.createElement('div');
                    dot.className = 'carousel-dot' + (i === currentPage ? ' active' : '');
                    dot.addEventListener('click', () => goTo(i));
                    dots.appendChild(dot);
                }
            }

            function renderCards() {
                track.classList.add('fading');
                setTimeout(() => {
                    const start = currentPage * CARDS_PER_PAGE;
                    const items = newsItems.slice(start, start + CARDS_PER_PAGE);
                    track.innerHTML = '';

                    items.forEach((item, idx) => {
                        const globalIdx = start + idx;
                        const card = document.createElement('div');
                        card.className = 'carousel-card';
                        card.style.cursor = 'pointer';

                        const catEl = document.createElement('p');
                        catEl.className = 'carousel-card__category';
                        catEl.textContent = item.category;

                        const titleEl = document.createElement('h3');
                        titleEl.className = 'carousel-card__title';
                        titleEl.textContent = item.title;

                        const bodyDiv = document.createElement('div');
                        bodyDiv.appendChild(catEl);
                        bodyDiv.appendChild(titleEl);

                        if (item.summary) {
                            const summaryEl = document.createElement('p');
                            summaryEl.className = 'carousel-card__summary';
                            summaryEl.textContent = item.summary;
                            bodyDiv.appendChild(summaryEl);
                        }

                        const metaDiv = document.createElement('div');
                        metaDiv.className = 'carousel-card__meta';
                        metaDiv.innerHTML = `<span>${item.source}</span><span class="carousel-card__meta-dot"></span><span>${item.date}</span>`;

                        const accentLine = document.createElement('div');
                        accentLine.className = 'carousel-card__accent-line';

                        card.appendChild(bodyDiv);
                        card.appendChild(metaDiv);
                        card.appendChild(accentLine);

                        card.addEventListener('click', () => openNewsModal(newsItems[globalIdx]));
                        track.appendChild(card);
                    });

                    counter.textContent = `${currentPage + 1} / ${totalPages}`;
                    track.classList.remove('fading');
                    renderDots();
                }, 250);
            }

            function startProgress() {
                progress.style.transition = 'none';
                progress.style.width = '0%';
                progressStart = Date.now();
                requestAnimationFrame(function tick() {
                    const elapsed = Date.now() - progressStart;
                    const pct = Math.min((elapsed / INTERVAL_MS) * 100, 100);
                    progress.style.width = pct + '%';
                    if (pct < 100) requestAnimationFrame(tick);
                });
            }

            function goTo(page) {
                currentPage = (page + totalPages) % totalPages;
                renderCards();
                clearInterval(timer);
                startProgress();
                timer = setInterval(advance, INTERVAL_MS);
            }

            function advance() { goTo(currentPage + 1); }

            document.getElementById('carouselPrev').addEventListener('click', () => goTo(currentPage - 1));
            document.getElementById('carouselNext').addEventListener('click', () => goTo(currentPage + 1));

            renderCards();
            startProgress();
            timer = setInterval(advance, INTERVAL_MS);
        </script>
    }

    <!-- ARTÍCULOS DESTACADOS -->
    <section class="section" id="articles">
        <div class="section__header">
            <div>
                <p class="section__label">Últimas entradas</p>
                <h2 class="section__title reveal">Artículos<br>destacados</h2>
            </div>
            <a asp-area="Identity" asp-page="/Account/Login" class="section__link">Ver todos →</a>
        </div>

        @{
            var displayItems = Model.FeaturedItems.Any() ? Model.FeaturedItems : null;
        }

        @if (displayItems is not null && displayItems.Any())
        {
            <div class="articles-grid">
                @{
                    var first = displayItems.First();
                }
                <div class="card card--featured reveal news-card" style="cursor:pointer;"
                     data-title="@Html.Encode(first.Normalized?.Title ?? "Sin título")"
                     data-summary="@Html.Encode(first.Normalized?.Summary ?? first.Normalized?.Content?.Substring(0, Math.Min(200, first.Normalized?.Content?.Length ?? 0)) ?? "")"
                     data-category="@Html.Encode(first.Normalized?.Category?.Primary ?? "General")"
                     data-source="@Html.Encode(first.Source?.Name ?? first.Schema?.Name ?? "Fuente")"
                     data-date="@first.Normalized?.PublishedAt.ToString("dd MMM yyyy")"
                     data-url="@Html.Encode(first.Normalized?.Url ?? "#")"
                     data-image="@Html.Encode(first.Normalized?.ImageUrl ?? "")"
                     data-source-item-id="@first.SourceItemId">
                    <p class="card__category">@(first.Normalized?.Category?.Primary ?? "General")</p>
                    <h3 class="card__title">@(first.Normalized?.Title ?? "Sin título")</h3>
                    <p class="card__summary">@(first.Normalized?.Summary ?? first.Normalized?.Content?.Substring(0, Math.Min(200, first.Normalized?.Content?.Length ?? 0)))</p>
                    <div class="card__meta">
                        <span>@(first.Source?.Name ?? first.Schema?.Name ?? "Fuente")</span>
                        <span class="card__meta-dot"></span>
                        <span>@(first.Normalized?.PublishedAt.ToString("dd MMM yyyy"))</span>
                    </div>
                    <div class="card__accent-line"></div>
                </div>

                @foreach (var item in displayItems.Skip(1).Take(4))
                {
                    <div class="card reveal news-card" style="cursor:pointer;"
                         data-title="@Html.Encode(item.Normalized?.Title ?? "Sin título")"
                         data-summary="@Html.Encode(item.Normalized?.Summary ?? item.Normalized?.Content?.Substring(0, Math.Min(200, item.Normalized?.Content?.Length ?? 0)) ?? "")"
                         data-category="@Html.Encode(item.Normalized?.Category?.Primary ?? "General")"
                         data-source="@Html.Encode(item.Source?.Name ?? item.Schema?.Name ?? "Fuente")"
                         data-date="@item.Normalized?.PublishedAt.ToString("dd MMM")"
                         data-url="@Html.Encode(item.Normalized?.Url ?? "#")"
                         data-image="@Html.Encode(item.Normalized?.ImageUrl ?? "")"
                         data-source-item-id="@item.SourceItemId">
                        <p class="card__category">@(item.Normalized?.Category?.Primary ?? "General")</p>
                        <h3 class="card__title">@(item.Normalized?.Title ?? "Sin título")</h3>
                        <div class="card__meta">
                            <span>@(item.Source?.Name ?? item.Schema?.Name ?? "Fuente")</span>
                            <span class="card__meta-dot"></span>
                            <span>@(item.Normalized?.PublishedAt.ToString("dd MMM"))</span>
                        </div>
                        <div class="card__accent-line"></div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="articles-grid">
                @for (int i = 0; i < 5; i++)
                {
                    <div class="card @(i == 0 ? "card--featured" : "") reveal">
                        <p class="card__category">Tecnología</p>
                        <h3 class="card__title">@(i == 0 ? "El futuro del periodismo digital está en la agregación inteligente de fuentes" : $"Artículo de ejemplo {i + 1}")</h3>
                        @if (i == 0)
                        {
                            <p class="card__summary">Los nuevos sistemas de agregación permiten centralizar contenido de múltiples fuentes en tiempo real, transformando la forma en que consumimos información.</p>
                        }
                        <div class="card__meta">
                            <span>Example News</span>
                            <span class="card__meta-dot"></span>
                            <span>@DateTime.Now.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="card__accent-line"></div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- CÓMO FUNCIONA -->
    <section class="section how-section" id="how">
        <div class="section__header">
            <div>
                <p class="section__label">El proceso</p>
                <h2 class="section__title reveal">Cómo<br>funciona</h2>
            </div>
        </div>
        <div class="steps-grid">
            <div class="step reveal">
                <div class="step__number">01</div>
                <h3 class="step__title">Conecta tus fuentes</h3>
                <p class="step__desc">Agrega URLs de APIs, feeds RSS o endpoints JSON. FlowPress las lee y normaliza automáticamente.</p>
            </div>
            <div class="step reveal">
                <div class="step__number">02</div>
                <h3 class="step__title">Explora el contenido</h3>
                <p class="step__desc">El contenido se parsea y presenta de forma limpia. Filtra por fuente, categoría o fecha.</p>
            </div>
            <div class="step reveal">
                <div class="step__number">03</div>
                <h3 class="step__title">Guarda lo que importa</h3>
                <p class="step__desc">Guarda artículos en la base de datos, exporta a JSON e importa contenido de otros sistemas.</p>
            </div>
        </div>
    </section>

    <!-- FUENTES -->
    <section class="section" id="sources">
        <div class="section__header">
            <div>
                <p class="section__label">Fuentes activas</p>
                <h2 class="section__title reveal">De dónde<br>viene el contenido</h2>
            </div>
        </div>
        <div class="sources-grid">
            @if (Model.Sources.Any())
            {
                @foreach (var source in Model.Sources)
                {
                    <div class="source-card reveal">
                        <p class="source-card__type">@source.ComponentType</p>
                        <h3 class="source-card__name">@source.Name</h3>
                        <p class="source-card__url">@source.Url</p>
                    </div>
                }
            }
            else
            {
                <div class="source-card reveal">
                    <p class="source-card__type">API</p>
                    <h3 class="source-card__name">Example News</h3>
                    <p class="source-card__url">https://example.com/feed</p>
                </div>
                <div class="source-card reveal">
                    <p class="source-card__type">Feed</p>
                    <h3 class="source-card__name">Tech Today</h3>
                    <p class="source-card__url">https://techtoday.com/api</p>
                </div>
                <div class="source-card reveal">
                    <p class="source-card__type">Widget</p>
                    <h3 class="source-card__name">Global Press</h3>
                    <p class="source-card__url">https://globalpress.io/feed</p>
                </div>
            }
        </div>
    </section>

    <!-- CTA FINAL -->
    <section class="cta-section">
        <div class="cta-section__bg"></div>
        @if (!User.Identity.IsAuthenticated)
        {
            <h2 class="cta-section__title reveal">Empieza<br><em>hoy.</em></h2>
            <p class="cta-section__sub reveal">Accede a tu cuenta y comienza a agregar fuentes.</p>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn-primary reveal">Ir al login</a>
        }
        else
        {
            <h2 class="cta-section__title reveal">Bienvenido,<br><em>@User.Identity.Name</em></h2>
            <p class="cta-section__sub reveal">Ya estás dentro. Explora el contenido.</p>
            <a href="#articles" class="btn-primary reveal">Ver artículos</a>
        }
    </section>

    <!-- FOOTER -->
    <footer>
        <div class="footer__logo">Flow<span>Press</span></div>
        <p class="footer__copy">SC-701 · Programación Avanzada Web · @DateTime.Now.Year</p>
    </footer>

    <script src="~/js/animations.js"></script>

    <script>
        // ── Estado del modal ──────────────────────────────────────────
        let currentModalItem = null;

        // ── Abrir modal ───────────────────────────────────────────────
        function openNewsModal(item) {
            currentModalItem = item;

            document.getElementById('modal-title').textContent    = item.title    || 'Sin título';
            document.getElementById('modal-summary').textContent  = item.summary  || 'Sin descripción disponible.';
            document.getElementById('modal-category').textContent = item.category || '';
            document.getElementById('modal-source').textContent   = (item.source  || '').toUpperCase();
            document.getElementById('modal-date').textContent     = item.date     || '';
            document.getElementById('modal-link').href            = item.url      || '#';

            const imgEl = document.getElementById('modal-image');
            if (item.image) {
                imgEl.src           = item.image;
                imgEl.style.display = 'block';
            } else {
                imgEl.src           = '';
                imgEl.style.display = 'none';
            }

            const modal = document.getElementById('newsModal');
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        // ── Cerrar modal ──────────────────────────────────────────────
        function closeNewsModal() {
            document.getElementById('newsModal').style.display = 'none';
            document.body.style.overflow = '';
            currentModalItem = null;
        }

        // ── Descargar JSON ────────────────────────────────────────────
        async function downloadArticleJson() {
            if (!currentModalItem) return;

            const date = new Date().toISOString().slice(0, 10).replace(/-/g, '');

            // Artículo destacado — tiene ID en BD, el backend arma el JSON completo
            if (currentModalItem.sourceItemId && currentModalItem.sourceItemId > 0) {
                const url = `?handler=ExportArticle&id=${currentModalItem.sourceItemId}`;
                const a   = document.createElement('a');
                a.href     = url;
                a.download = `article_${currentModalItem.sourceItemId}_${date}.json`;
                a.click();
                return;
            }

            // Artículo del carrusel — viene de API, armamos el JSON en el cliente
            const payload = {
                schemaVersion: "edu.univ.ingest.v1",
                exportedAt: new Date().toISOString(),
                source: {
                    id:             currentModalItem.sourceId       || null,
                    name:           currentModalItem.source         || null,
                    type:           "api",
                    url:            currentModalItem.sourceUrl      || null,
                    requiresSecret: currentModalItem.requiresSecret || false
                },
                normalized: {
                    id:          null,
                    externalId:  currentModalItem.externalId  || null,
                    title:       currentModalItem.title        || null,
                    content:     currentModalItem.content      || null,
                    summary:     currentModalItem.summary      || null,
                    publishedAt: currentModalItem.publishedAt  || null,
                    url:         currentModalItem.url          || null,
                    author:      currentModalItem.author       || null,
                    language:    currentModalItem.language     || null,
                    category: {
                        primary:   currentModalItem.category            || null,
                        secondary: currentModalItem.secondaryCategories || []
                    }
                },
                raw: {
                    format: "json",
                    data: { note: "Raw data no disponible para artículos en tiempo real." }
                }
            };

            const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
            const blobUrl = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href     = blobUrl;
            a.download = `article_${date}.json`;
            a.click();
            URL.revokeObjectURL(blobUrl);
        }

        // ── Cerrar con fondo o Escape ─────────────────────────────────
        document.getElementById('newsModal').addEventListener('click', function(e) {
            if (e.target === this) closeNewsModal();
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeNewsModal();
        });

        function decodeHtml(str) {
        if (!str) return '';
        const txt = document.createElement('textarea');
        txt.innerHTML = str;
        return txt.value;
}
        // ── Cards de artículos destacados ─────────────────────────────
        document.querySelectorAll('.news-card').forEach(card => {
            card.addEventListener('click', () => {
                openNewsModal({
                    title:          decodeHtml(card.dataset.title),
                    summary:        decodeHtml(card.dataset.summary),
                    category:       decodeHtml(card.dataset.category),
                    source:         decodeHtml(card.dataset.source),
                    date:           card.dataset.date,
                    url:            card.dataset.url,
                    image:          card.dataset.image,
                    sourceItemId:   parseInt(card.dataset.sourceItemId || '0')
                });
            });
        });
    </script>
</body>
</html>
